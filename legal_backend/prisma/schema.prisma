generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firebaseUid  String?  @unique
  phone        String?
  name         String?
  passwordHash String?
  userType     String   @default("CONSUMER")
  countryCode  String?
  jurisdiction String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  consumerProfile   ConsumerProfile?
  tenantUsers       TenantUser[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  consumerCases     ConsumerCase[]
  consumerDocuments ConsumerDocument[]
  consumerReports   ConsumerLegalReport[]
  lawyerProfile     LawyerProfile?
  aiOutputs         AIOutput[]
  aiUsageLogs       AIUsageLog[]
  matterAccess      MatterAccess[]
  copilotSessions   CopilotSession[]
  uploadedDocuments Document[]       @relation("DocumentUploader")
  portalDocumentRequests PortalDocumentRequest[] @relation("PortalRequestRequester")
  portalMessages         PortalMessage[]         @relation("PortalMessageSender")
  notifications     Notification[]
  deviceTokens      DeviceToken[]
  trainingConsents  TrainingConsent[]
  documentTrainingPermissions DocumentTrainingPermission[]
  aiCreditLedger    AICreditLedger[]
  aiBudgetPolicies  AIBudgetPolicy[]
  lawyerLeads       LawyerLead[]
  preferences       UserPreferences?
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("LAW_FIRM")
  primaryCountry  String
  defaultCurrency String
  billingPlan     String?
  aiCreditsRemaining Int @default(0)
  aiModelMode     String   @default("AUTO")
  premiumModelId  String   @default("gpt-4.1")
  autoTopUpEnabled Boolean @default(false)
  autoTopUpThresholdCredits Int @default(10)
  autoTopUpPackId String   @default("pack_25")
  stripeCustomerId String?
  stripePaymentMethodId String?
  autoTopUpLastTriggeredAt DateTime?
  dataRegion      String?
  ssoConfig       Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantUsers TenantUser[]
  clients     Client[]
  matters     Matter[]
  documents   Document[]
  timeEntries TimeEntry[]
  invoices    Invoice[]
  trustAccounts TrustAccount[]
  tasks       Task[]
  calendarEvents CalendarEvent[]
  auditLogs   AuditLog[]
  subscriptions Subscription[]
  payments    Payment[]
  aiOutputs          AIOutput[]
  aiUsageLogs        AIUsageLog[]
  meetings           Meeting[]
  alerts             Alert[]
  documentTemplates  DocumentTemplate[]
  expenses           Expense[]
  claims             Claim[]
  fixedCosts         FixedCost[]
  automationRules    AutomationRule[]
  notifications      Notification[]
  timelineEvents     TimelineEvent[]
  assistanceRequests AssistanceRequest[]
  documentFolders    DocumentFolder[]
  documentVersions   DocumentVersion[]
  documentAccessRules DocumentAccessRule[]
  firmProfile        FirmProfile?
  documentPolicies   DocumentPolicy[]
  accessPolicies     AccessPolicy[]
  portalDocumentRequests PortalDocumentRequest[]
  portalMessages         PortalMessage[]
  matterPlaybooks       MatterPlaybook[]
  trainingConsents      TrainingConsent[]
  documentTrainingPermissions DocumentTrainingPermission[]
  aiCreditLedger        AICreditLedger[]
  aiBudgetPolicies      AIBudgetPolicy[]
  lawyerLeads           LawyerLead[]
  caseAnalysisRuns      CaseAnalysisRun[]
  matterIssues          MatterIssue[]
  matterArguments       MatterArgument[]
  matterStrategyMemos   MatterStrategyMemo[]
  matterParties         MatterParty[]
  conflictChecks        ConflictCheck[]
  matterOutcomeAnalyses MatterOutcomeAnalysis[]
  courtCases            CourtCase[]
  integrationConnections IntegrationConnection[]
  rateTables            RateTable[]
  preBillSessions       PreBillSession[]
  trustReconciliations  TrustReconciliation[]
  suggestedTimeEntries  SuggestedTimeEntry[]
  marketplaceRevenue    MarketplaceRevenueEntry[]
  evidenceItems         EvidenceItem[]
  ethicalWallGroups     EthicalWallGroup[]
  webhookSubscriptions  WebhookSubscription[]
  publicApiKeys         PublicApiKey[]
  bulkDocReviewJobs     BulkDocumentReviewJob[]
  integrationSyncLogs   IntegrationSyncLog[]
  unifiedInboxThreads   UnifiedInboxThread[]
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model ConsumerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  countryCode        String
  stateOrCounty      String?
  preferredLanguage  String   @default("en")
  subscriptionStatus String   @default("FREE")
  aiCreditsRemaining Int      @default(3)
  aiModelMode     String   @default("AUTO")
  premiumModelId  String   @default("gpt-4.1")
  autoTopUpEnabled Boolean @default(false)
  autoTopUpThresholdCredits Int @default(10)
  autoTopUpPackId String   @default("pack_25")
  stripeCustomerId String?
  stripePaymentMethodId String?
  autoTopUpLastTriggeredAt DateTime?
  governanceSettings Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsumerCase {
  id              String   @id @default(cuid())
  userId          String
  countryCode     String
  jurisdiction    String?
  issueType       String
  title           String
  facts           String?
  desiredOutcome  String?
  urgencyLevel    String   @default("LOW")
  riskScore       Float?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents       ConsumerDocument[]
  reports         ConsumerLegalReport[]
  reviewRequests  LawyerReviewRequest[]

  @@index([userId])
  @@index([countryCode, issueType])
}

model ConsumerDocument {
  id             String   @id @default(cuid())
  userId         String
  consumerCaseId String
  fileName       String
  fileUrl        String
  mimeType       String?
  fileSizeBytes  Int?
  documentType   String?
  extractedText  String?
  aiSummary      String?
  ocrStatus      String   @default("PENDING")
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumerCase   ConsumerCase @relation(fields: [consumerCaseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consumerCaseId])
}

model ConsumerLegalReport {
  id                 String   @id @default(cuid())
  userId             String
  consumerCaseId     String
  countryCode        String
  reportType         String
  title              String
  contentMarkdown    String
  citations          Json?
  riskLevel          String?
  requiresLawyer     Boolean  @default(false)
  lawyerReviewStatus String   @default("NOT_REQUESTED")
  reviewedByLawyerId String?
  isPreview          Boolean  @default(false)
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumerCase       ConsumerCase @relation(fields: [consumerCaseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consumerCaseId])
}

model LawyerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tenantId           String?
  countryCode        String
  barNumber          String?
  verified           Boolean  @default(false)
  verificationStatus String   @default("PENDING")
  practiceAreas      Json
  jurisdictions      Json
  languages          Json
  consultationFee    Decimal? @db.Decimal(10, 2)
  currency           String
  acceptsLeads       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LawyerReviewRequest {
  id               String   @id @default(cuid())
  consumerCaseId   String
  consumerReportId String?
  userId           String
  countryCode      String
  jurisdiction     String?
  issueType        String
  status           String   @default("OPEN")
  assignedLawyerId String?
  assignedTenantId String?
  price            Decimal  @db.Decimal(10, 2)
  currency         String
  createdAt        DateTime @default(now())
  completedAt      DateTime?
  consumerCase     ConsumerCase @relation(fields: [consumerCaseId], references: [id], onDelete: Cascade)

  @@index([countryCode, issueType, status])
}

model Client {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  email       String?
  phone       String?
  type        String   @default("INDIVIDUAL")
  countryCode String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matters       Matter[]
  documents     Document[]
  kycChecklists KycChecklist[]
  kycDocuments  KycDocument[]
  documentFolders DocumentFolder[]
  portalDocumentRequests PortalDocumentRequest[]
  portalMessages         PortalMessage[]

  @@index([tenantId])
}

model Matter {
  id                String   @id @default(cuid())
  tenantId          String
  clientId          String?
  title             String
  countryCode       String
  jurisdiction      String?
  courtName         String?
  courtLevel        String?
  caseNumber        String?
  practiceArea      String
  matterType        String
  status            String   @default("OPEN")
  stage             String?
  factsSummary      String?
  legalIssues       Json?
  desiredOutcome    String?
  opposingParty     String?
  riskScore         Float?
  aiConfidenceScore Float?
  retainerBalance   Decimal? @db.Decimal(12, 2)
  retainerCurrency  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client            Client?  @relation(fields: [clientId], references: [id])
  facts             MatterFact[]
  documents         Document[]
  timeEntries       TimeEntry[]
  tasks             Task[]
  calendarEvents     CalendarEvent[]
  matterAccess       MatterAccess[]
  meetings           Meeting[]
  expenses           Expense[]
  claims             Claim[]
  timelineEvents     TimelineEvent[]
  assistanceRequests AssistanceRequest[]
  documentFolders    DocumentFolder[]
  portalDocumentRequests PortalDocumentRequest[]
  portalMessages         PortalMessage[]
  matterIssues           MatterIssue[]
  matterArguments        MatterArgument[]
  matterStrategyMemos    MatterStrategyMemo[]
  matterParties          MatterParty[]
  outcomeAnalyses        MatterOutcomeAnalysis[]
  courtCases             CourtCase[]
  evidenceItems          EvidenceItem[]
  bulkDocReviewJobs      BulkDocumentReviewJob[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model MatterPlaybook {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  matterType  String?
  countryCode String?
  jurisdiction String?
  practiceArea String?
  taskTemplates Json
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isEnabled])
  @@index([tenantId, matterType, countryCode])
}

model MatterAccess {
  id          String   @id @default(cuid())
  tenantId    String
  matterId    String
  userId      String
  accessLevel String   @default("READ_ONLY")
  grantedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matter      Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matterId, userId])
  @@index([tenantId, userId])
  @@index([matterId])
}

model MatterFact {
  id               String   @id @default(cuid())
  tenantId         String
  matterId         String
  factText         String
  sourceType       String
  sourceId         String?
  confidence       Float    @default(0.5)
  isDisputed       Boolean  @default(false)
  approvedByLawyer Boolean  @default(false)
  createdAt        DateTime @default(now())
  matter           Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([tenantId, matterId])
}

model Document {
  id             String    @id @default(cuid())
  tenantId       String
  matterId       String?
  clientId       String?
  folderId       String?
  documentCode   String    @unique @default(cuid())
  fileName       String
  fileUrl        String
  mimeType       String?
  visibility     String    @default("PRIVATE")
  uploadedById   String?
  retentionUntil DateTime?
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter         Matter?   @relation(fields: [matterId], references: [id])
  client         Client?   @relation(fields: [clientId], references: [id])
  folder         DocumentFolder? @relation(fields: [folderId], references: [id])
  uploadedBy     User?     @relation("DocumentUploader", fields: [uploadedById], references: [id])
  versions       DocumentVersion[]
  accessRules    DocumentAccessRule[]

  @@index([tenantId])
  @@index([matterId])
  @@index([clientId])
  @@index([folderId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  tenantId    String
  matterId    String?
  userId      String
  date        DateTime
  minutes     Int
  narrative   String?
  billable    Boolean  @default(true)
  rate        Decimal? @db.Decimal(10, 2)
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter      Matter?  @relation(fields: [matterId], references: [id])

  @@index([tenantId])
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String?
  invoiceNumber String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String
  status        String   @default("DRAFT")
  dueDate       DateTime?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TrustAccount {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries   TrustLedgerEntry[]

  @@index([tenantId])
}

model TrustLedgerEntry {
  id          String   @id @default(cuid())
  accountId   String
  matterId    String?
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  status      String   @default("COMPLETED")
  reviewedById String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime @default(now())
  account     TrustAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([matterId])
}

model Task {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String?
  title     String
  status    String   @default("TODO")
  priority  String   @default("MEDIUM")
  dueDate   DateTime?
  assigneeId String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter    Matter?  @relation(fields: [matterId], references: [id])

  @@index([tenantId])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String?
  title     String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter    Matter?  @relation(fields: [matterId], references: [id])

  @@index([tenantId])
}

model LegalAuthority {
  id              String   @id @default(cuid())
  countryCode     String
  jurisdiction    String?
  authorityType   String
  title           String
  citation        String?
  court           String?
  courtLevel      String?
  decisionDate    DateTime?
  sourceUrl       String?
  sourceName      String
  sourceLicense   String?
  fullText        String?
  summary         String?
  holding         String?
  topics          Json
  practiceAreas   Json
  embeddingStatus String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  citations       AICitation[]

  @@index([countryCode, jurisdiction])
  @@index([citation])
}

model AIOutput {
  id                   String   @id @default(cuid())
  userId               String?
  tenantId             String?
  consumerCaseId       String?
  matterId             String?
  mode                 String
  taskType             String
  promptHash           String?
  outputMarkdown       String
  citations            Json?
  confidenceScore      Float?
  riskLevel            String?
  requiresLawyerReview Boolean  @default(false)
  approvedByLawyerId   String?
  createdAt            DateTime @default(now())
  user                 User?    @relation(fields: [userId], references: [id])
  tenant               Tenant?  @relation(fields: [tenantId], references: [id])
  aiCitations          AICitation[]

  @@index([tenantId])
  @@index([userId])
}

model AIUsageLog {
  id             String   @id @default(cuid())
  userId         String?
  tenantId       String?
  consumerCaseId String?
  matterId       String?
  taskType       String
  mode           String
  modelProvider  String
  modelName      String
  modelTier      String?
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  retrievalCount Int      @default(0)
  costUsd        Decimal? @db.Decimal(10, 4)
  estimatedCostUsd Decimal? @db.Decimal(10, 6)
  chargedCredits Int      @default(0)
  creditValueUsd Decimal? @db.Decimal(10, 6)
  platformMarginUsd Decimal? @db.Decimal(10, 6)
  latencyMs      Int?
  status         String
  error          String?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model AICitation {
  id           String   @id @default(cuid())
  userId       String?
  tenantId     String?
  aiOutputId   String
  authorityId  String?
  documentId   String?
  sourceUrl    String?
  quotedText   String?
  paragraphRef String?
  confidence   Float    @default(0.5)
  createdAt    DateTime @default(now())
  aiOutput     AIOutput @relation(fields: [aiOutputId], references: [id], onDelete: Cascade)
  authority    LegalAuthority? @relation(fields: [authorityId], references: [id])

  @@index([aiOutputId])
}

model Subscription {
  id                     String   @id @default(cuid())
  userId                 String?
  tenantId               String?
  userType               String
  countryCode            String
  currency               String
  planId                 String
  status                 String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean  @default(false)
  paymentProvider        String
  providerCustomerId     String?
  providerSubscriptionId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String?
  tenantId          String?
  countryCode       String
  currency          String
  amount            Decimal  @db.Decimal(10, 2)
  paymentProvider   String
  providerPaymentId String?
  status            String
  purpose           String
  metadata          Json?
  createdAt         DateTime @default(now())
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Receipt {
  id           String   @id @default(cuid())
  paymentId    String   @unique
  tenantId     String?
  invoiceId    String?
  receiptNumber String
  amount       Decimal  @db.Decimal(10, 2)
  currency     String
  issuedAt     DateTime @default(now())
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([invoiceId])
  @@index([issuedAt])
}

model CountryPricing {
  id          String   @id @default(cuid())
  countryCode String
  userType    String
  planId      String
  currency    String
  amount      Decimal  @db.Decimal(10, 2)
  aiCredits   Int      @default(0)
  features    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([countryCode, userType, planId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model AgentJob {
  id          String   @id @default(cuid())
  queue       String
  jobType     String
  status      String   @default("QUEUED")
  userId      String?
  tenantId    String?
  payload     Json?
  result      Json?
  error       String?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  @@index([status])
  @@index([queue])
}

model CopilotSession {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  userRole  String?
  context   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CopilotMessage[]
  auditLogs CopilotAuditLog[]

  @@index([tenantId, userId])
}

model CopilotMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  toolCalls Json?
  citations Json?
  createdAt DateTime @default(now())
  session   CopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model CopilotAuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  userRole  String?
  sessionId String?
  action    String
  toolName  String?
  payload   Json?
  result    Json?
  error     String?
  createdAt DateTime @default(now())
  session   CopilotSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([sessionId])
}

model Meeting {
  id                         String    @id @default(cuid())
  tenantId                   String
  matterId                   String?
  clientId                   String?
  createdByUserId            String?
  title                      String
  status                     String    @default("draft")
  source                     String    @default("manual_recording")
  confidentiality            String    @default("standard")
  participants               Json?
  visibilityAllowListUserIds Json?
  scheduledAt                DateTime?
  durationMin                Int?
  durationMs                 Int?
  audioStorageKey            String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  tenant                     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter                     Matter?   @relation(fields: [matterId], references: [id])
  transcripts                MeetingTranscript[]
  notes                      MeetingNote[]

  @@index([tenantId])
  @@index([matterId])
  @@index([clientId])
  @@index([createdByUserId])
}

model MeetingTranscript {
  id        String   @id @default(cuid())
  tenantId  String
  meetingId String
  content   String
  source    String?
  createdAt DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([meetingId])
}

model MeetingNote {
  id          String   @id @default(cuid())
  tenantId    String
  meetingId   String
  content     String
  createdById String?
  createdAt   DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([meetingId])
