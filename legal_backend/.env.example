NODE_ENV=development
PORT=4000
APP_NAME="Legal by OdaFlow"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legal_odaflow
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legal_odaflow
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_me_jwt_secret
FIREBASE_PROJECT_ID=legal-6a437
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_me_refresh_secret
REFRESH_TOKEN_EXPIRES_IN=30d
SESSION_COOKIE_SECRET=change_me_session_secret

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,https://legal-three-red.vercel.app

AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
AI_FAST_MODEL=gpt-4.1-mini
AI_CHEAP_MODEL=gpt-4.1-mini
AI_MID_MODEL=gpt-4.1
AI_REASONING_MODEL=gpt-4.1
AI_ENABLE_MODEL_ROUTING=true
AI_BLOCK_TASK_IF_MARGIN_NEGATIVE=true
AI_ALLOW_NEGATIVE_MARGIN_FOR_FREE_PREVIEW=true
AI_MIN_GROSS_MARGIN_PERCENT=65
ENABLE_CREDIT_RESERVATIONS=false
CREDIT_RESERVATION_TTL_MS=900000
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_MONTHLY_TENANT_COST_USD=500
AI_MAX_MONTHLY_CONSUMER_COST_USD=25
AI_REQUIRE_CITATIONS=true
AI_REQUIRE_APPROVAL_FOR_LEGAL_DRAFTS=true
AI_CONSUMER_DISCLAIMER_REQUIRED=true
AI_DEFAULT_MAX_TASK_COST_USD=0.25
AI_DEFAULT_MONTHLY_USER_BUDGET_USD=10
AI_DEFAULT_MONTHLY_TENANT_BUDGET_USD=500
AI_ENABLE_RESPONSE_CACHE=true
AI_ENABLE_EMBEDDING_CACHE=true
AI_ENABLE_RAG=true
AI_ENABLE_AGENTS=true
AI_ENABLE_LEGAL_RESEARCH=true
AI_ENABLE_OUTCOME_RISK=true
AI_ENABLE_CONSUMER_GUIDANCE=true
AI_REQUIRE_LAWYER_APPROVAL_FOR_HIGH_RISK=true

TRAINING_OPT_IN_DEFAULT=false
TRAINING_REQUIRE_EXPLICIT_CONSENT=true
TRAINING_ALLOW_FINE_TUNING=false
TRAINING_ALLOW_EVALUATION_DATASET=true
TRAINING_REQUIRE_ANONYMIZATION=true
TRAINING_DATA_REGION=us-east-1

ENABLE_LEGAL_CONNECTORS=true
COURTLISTENER_API_TOKEN=
COURTLISTENER_TOKEN=
ECOURTS_API_URL=
INDIA_KANOON_API_KEY=
LEGAL_CONNECTOR_CACHE_TTL_SECONDS=86400

VECTOR_PROVIDER=pgvector
ENABLE_OPENSEARCH=false

# AWS (IAM user with S3 + SQS access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
IAM_USER=

# S3 (public read URL pattern: https://{bucket}.s3.{region}.amazonaws.com/{object-key})
S3_PROVIDER=local
S3_BUCKET=legal-odaflow-dev
LEGAL_S3_BUCKET=legal-odaflow-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_CDN_URL=

# SQS
LEGAL_SQS_QUEUE_URL=

OCR_PROVIDER=azure
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=
MPESA_WEBHOOK_SECRET=
REQUIRE_PAYMENT_METHOD_FOR_LAWYER_TRIAL=false

EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=no-reply@legalbyodaflow.com

SENTRY_DSN=
LOG_LEVEL=debug

ENABLE_AUDIT_LOGS=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

SEED_ADMIN_EMAIL=admin@odaflow.com
SEED_ADMIN_PASSWORD=Admin123!ChangeMe

ENABLE_CONSUMER_APP=true
ENABLE_LAWYER_OS=true
ENABLE_LAWYER_MARKETPLACE=true
